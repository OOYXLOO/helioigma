{
  "name": "helioigma",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check game.js && node --check tools/browser-smoke-check.mjs && node --check tools/build-demo-video.mjs && node --check tools/build-demo-webm.mjs && node --check tools/capture-public-media.mjs && node --check tools/launch-readiness-audit.mjs",
    "preflight": "powershell -ExecutionPolicy Bypass -File ./public-preflight.ps1",
    "smoke": "node tools/browser-smoke-check.mjs",
    "audit:launch": "node tools/launch-readiness-audit.mjs",
    "audit:launch:public": "node tools/launch-readiness-audit.mjs --public",
    "build:media": "node tools/capture-public-media.mjs",
    "build:video": "node tools/build-demo-video.mjs",
    "build:webm": "node tools/build-demo-webm.mjs",
    "build:package": "powershell -ExecutionPolicy Bypass -File ./tools/build-package.ps1"
  },
  "devDependencies": {
    "playwright": "1.60.0"
  }
}
